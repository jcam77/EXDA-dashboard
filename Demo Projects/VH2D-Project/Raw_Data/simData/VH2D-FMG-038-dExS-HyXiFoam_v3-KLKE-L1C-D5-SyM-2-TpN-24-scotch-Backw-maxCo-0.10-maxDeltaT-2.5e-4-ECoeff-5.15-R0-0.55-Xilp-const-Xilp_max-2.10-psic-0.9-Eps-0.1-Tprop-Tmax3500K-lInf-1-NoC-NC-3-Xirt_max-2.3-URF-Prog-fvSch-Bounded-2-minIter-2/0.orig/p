FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    explosionChamber
    {
        type            zeroGradient;
    }
    ground
    {
        type            zeroGradient;
    }
    outletFarfield
    {
        type            waveTransmissive;
        field           p; //the name of the field that we are working on
        gamma           1.4;
        fieldInf        101325;
        lInf            1;
    }
}

