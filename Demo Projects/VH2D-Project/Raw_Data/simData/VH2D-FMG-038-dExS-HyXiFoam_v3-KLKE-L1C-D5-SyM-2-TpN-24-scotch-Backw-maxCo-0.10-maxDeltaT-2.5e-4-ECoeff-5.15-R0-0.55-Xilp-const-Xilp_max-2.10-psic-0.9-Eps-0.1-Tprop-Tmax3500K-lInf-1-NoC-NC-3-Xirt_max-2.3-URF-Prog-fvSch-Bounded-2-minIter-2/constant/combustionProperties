FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      combustionProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

laminarFlameSpeedCorrelation constant;

fuel            Hydrogen;

Su              Su [0 1 -1 0 0 0 0] 0.64;

SuModel         unstrained;

equivalenceRatio equivalenceRatio [0 0 0 0 0 0 0] 0.523;

sigmaExt        sigmaExt [0 0 -1 0 0 0 0] 100000;

XiModel         HyAlgebraicXi;//XiModel-001;//algebraic_new;

XiCoef          XiCoef [0 0 0 0 0 0 0] 0.62; // Used in the algebraic Xi model

XiShapeCoef     XiShapeCoef [0 0 0 0 0 0 0] 1;

uPrimeCoef      uPrimeCoef [0 0 0 0 0 0 0] 1;


ignite          yes;

ignitionSites
(
    {
        location          (2.4 0.0 1.5); // added by JCAM
        // location       (2.3 0.0 1.5);
        //location       (2.3 0.005 1.5);
        //diameter        0.102;  //cell size
        diameter        0.2519;//0.1254;//0.1342;//0.0916;//0.0567;   //cell size
        start           0;
        //duration        0.015;
        duration        0.03785;//0.01885;//0.02005;//0.0137;//0.00832;
        strength        1;//5;
    }
);

ignitionSphereFraction 1;

ignitionThickness ignitionThickness [0 1 0 0 0 0 0] 1;

ignitionCircleFraction 1;

ignitionKernelArea ignitionKernelArea [0 2 0 0 0 0 0] 1;


