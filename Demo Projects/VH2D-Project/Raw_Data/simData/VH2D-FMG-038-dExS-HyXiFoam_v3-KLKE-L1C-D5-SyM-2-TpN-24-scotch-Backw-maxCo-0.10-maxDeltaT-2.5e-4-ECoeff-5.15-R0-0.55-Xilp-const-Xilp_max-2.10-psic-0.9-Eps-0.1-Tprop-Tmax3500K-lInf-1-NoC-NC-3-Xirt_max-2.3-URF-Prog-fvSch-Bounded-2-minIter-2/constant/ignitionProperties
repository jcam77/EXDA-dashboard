FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      ignitionProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


// ignitionlocation         ignitionlocation [0 1 0 0 0 0 0] (2.3 0 1.5);
ignitionlocation         ignitionlocation [0 1 0 0 0 0 0] (2.4 0 1.5);// added by JCAM

R0_ign                       R0_ign [0 1 0 0 0 0 0] 0.55;//0.6;//0.65;//0.7;//1.0;//0.5;//1.0;//0.5;//0.4;//0.5;//0.8;//1.0;

// Xilp                     Xilp [0 0 0 0 0 0 0] 1.96;

Xilp_max                 Xilp_max [0 0 0 0 0 0 0] 2.10;//1.85;//1.96;// adjusted by JCAM based on Tolias & Venetsanos

useXilpRamp                 no;//yes; // if no Xilp_transitiondistCoeff will be ignored and tehn Xilp = Xilp_max always

Xilp_transitiondistCoeff   Xilp_transitiondistCoeff [0 0 0 0 0 0 0] 8;//16;//2;//10;// adjusted by JCAM, use a value based on the cell size inside the ignition region

chemicaltimescale        tscale [0 0 1 0 0 0 0] 0.000578;

psic                     psic [0 0 0 0 0 0 0] 0.9;//0.8;//0.9;//0.725;//0.8;//0.9;//0.725;//0.75;//0.9;

expansioncoefficient     E [0 0 0 0 0 0 0] 5.15;//5.20;//5.323;

useXirt     yes;//no;//yes;//no;//yes;//no;//yes;

Xirt_max    Xirt_max [0 0 0 0 0 0 0] 2.3;//2.0;//1.4;//1.6;//1.4;//1.5;//1.6;//1.4;//1.5;

rtBoxMin (4.8 0.0 0.3881);         // vent plane

rtBoxMax (5.0 1.1619 2.7119);      // 0.2 m thick, only over vent opening

// JCAM Switch: Enable/Disable b-clamping. Default to false()
clampB          off;//on;  // or off
