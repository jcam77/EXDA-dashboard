     pTProbes
    {
        type probes;
		libs            (sampling);
        interpolationScheme cellPoint; //cellPatchConstrained;//pointMVC;
		writeControl    timeStep;
        writeInterval   1;
		probeLocations
		(
		(2.4 2.295  1.5) //chamber pressure transducers added by JCAM
		);
		fields ( p T );
    } 

