//--- b Regression Variable ----------------------------------------------------
	bProbes // regression variable "b" probes // Added by JCAM
    {
        libs            (sampling);
        type probes;
		//writeControl   adjustableRunTime;
		//writeControl   runTime;
		//writeInterval  0.00001;
        // This OVERRIDES the global setting for this specific probe
        // It tells the solver: "Don't brake for me, just write what you have."
        writeControl    timeStep;
        writeInterval   1;
		//interpolationScheme cell;//cellPoint; //pointMVC; 	// Given cell centre values interpolates to vertices and uses these to do a Mean Value Coordinates interpolation.
        fields ( b );

	probeLocations
	(
    //Combustion Progress by tracking regression variable "b" (b=1 unburned, b=0 burned => c(progression variable) = 1-b)
    // from bEqn.H file     Info<< "Combustion progress  = 100*(scalar(1) - b)().weightedAverage(mesh.V()).value() << "%"
	(2.4 0.0 1.5) //ignition cell   added by JCAM   
	// (2.3 0.0 1.5) //ignition cell
	   //(2.3 0.005 1.5) //ignition cell
	);
    }
//--- up (Turbulent Fluctuating Velocity) probes -------------------------------
	upProbes
    {
        libs            (sampling);
        type probes;
        writeControl    timeStep;
        writeInterval   1;
		interpolationScheme cellPoint; //pointMVC; 	// Given cell centre values interpolates to vertices and uses these to do a Mean Value Coordinates interpolation.
        fields ( up );

	probeLocations
	(
	(3.4 0.005 1.5) 
	(4.4 0.005 1.5) 
	(5.4 0.005 1.5) 
	(5.9 0.005 1.5) 
	(6.2 0.005 1.5) 
	(6.7 0.005 1.5) 
	(8.2 0.005 1.5) 
	);
    }
//--- St (Turbulent Flame Speed) probes ----------------------------------------
	StProbes
    {
        libs            (sampling);
        type probes;
        writeControl    timeStep;
        writeInterval   1;
		interpolationScheme cellPoint; //pointMVC;; 	// Given cell centre values interpolates to vertices and uses these to do a Mean Value Coordinates interpolation.
        fields ( St );

	probeLocations
	(
	(3.4 0.005 1.5) 
	(4.4 0.005 1.5) 
	(5.4 0.005 1.5) 
	(5.9 0.005 1.5) 
	(6.2 0.005 1.5) 
	(6.7 0.005 1.5) 
	(8.2 0.005 1.5) 
	);
    }
//--- External Blast Wave Pressure Probes --------------------------------------
	bwpProbes // external blast wave pressure transducers
    {
        libs            (sampling);
        type probes;
        writeControl    timeStep;
        writeInterval   1;
		interpolationScheme cellPoint; //pointMVC;; 	// Given cell centre values interpolates to vertices and uses these to do a Mean Value Coordinates interpolation.
        fields ( p );

	probeLocations
	(
	(6.0 0.005 0.305) 
	(6.3 0.005 0.305) 
	(6.8 0.005 0.305) 
	(8.3 0.005 0.305) 
	);
    }

    //--- Method 1: Discrete Probes (For comparison with Bauwens Experiment) ---
    TOAProbs
    {
        type            probes;
        libs            ("libsampling.so"); // Standardized lib name
        enabled         true;               // Added enabled flag
        
        writeControl    timeStep;
        writeInterval   1;
        
        // cellPoint is definitely better than pointMVC for this
        interpolationScheme cellPoint; 
        
        fields          ( T b Tu );

        probeLocations
        (
            // Internal Probes (Approx 0.5m spacing)
            (0.4 0.005 1.4) 
            (0.9 0.005 1.4) 
            (1.4 0.005 1.4) 
            (1.9 0.005 1.4) 
            (2.4 0.005 1.4) 
            (2.9 0.005 1.4) 
            (3.4 0.005 1.4) 
            (3.9 0.005 1.4) 
            (4.4 0.005 1.4) 
            
            // External Probes (Verify these are inside your mesh!)
            (4.9 0.005 1.4) 
            (5.4 0.005 1.4) 
            (5.9 0.005 1.4) 
            (6.4 0.005 1.4) 
            (6.9 0.005 1.4) 
            (7.4 0.005 1.4) 
            (7.9 0.005 1.4) 
            (8.4 0.005 1.4)
        );
    }
    //--- Vent Flame TOA ---
    ventTOAProb
    {
        type            probes;
        libs            ("libsampling.so"); // Standardized lib name
        enabled         true;               // Added enabled flag
        
        writeControl    timeStep;
        writeInterval   1;
        
        // cellPoint is definitely better than pointMVC for this
        interpolationScheme cellPoint; 
        
        fields          (b);

        probeLocations
        (
            // Vent Probes (outer edge)
            (4.8 0.005 1.5) 
        );
    }

//---End of probes--------------------------------------------------------------

//-- Flow Characteristics Calculation ------------------------------------------
// 1. Get resolved variance (UPrime2Mean)
    fieldAverage1
    {
        type            fieldAverage;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        fields
        (
            U 
			{ 
				mean on; 
				prime2Mean on; 
				base time; 
			}
        );
    }

// -----------------------------------------------------------------------------
//-- Automatic time-discretization switch --------------------------------------
		/*
	NOTE: Automatic time-discretization switch
	- Purpose: start with Euler time derivative and switch to CrankNicolson 0.9 when ignition ends.
	- Mechanism: timeActivatedFileUpdate copies a template file onto <system>/fvSchemes at specified times.
	  The replacement is persistent (i.e., it stays on disk and survives restarts).
	- Files required in system/: fvSchemes (current), fvSchemes.Euler, fvSchemes.CN.
	- The (-1 ...) entry ensures Euler is applied at startup and on restarts before the switch time.
	- The 0.00832 s below should match ignitionSites.duration in constant/combustionProperties.
	- Prereq: runTimeModifiable must be true so the solver can pick up the change at runtime.
	*/
/* 	fvSchemesUpdate
	{
		type              timeActivatedFileUpdate;
		libs              (utilityFunctionObjects);
		writeControl      timeStep;
		writeInterval     1;

		// The file we want to replace at the switch time
		fileToUpdate      "<system>/fvSchemes";

		// Switch time => file to use from then on
		timeVsFile
		(
			(-1      "<system>/fvSchemes.Backward")
			// (-1      "<system>/fvSchemes.Euler")  // enforce Euler prior to ignition end (also on restarts)
			// (0.00832 "<system>/fvSchemes.CN")     // at t = ignitionSites.duration -> use CrankNicolson 0.9
		);
	} */
//--End of automatic time-discretization switch --------------------------------

