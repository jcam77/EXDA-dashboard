FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application    HyXiFoam_v3; //HyXiFoam_v1;//HyXiDyMFoam;

startFrom       latestTime;//startTime;

startTime       0;

stopAt          endTime;//writeNow;//this to pause the simulation, check that whe you re-start startFrom is set to latestTime;

endTime         0.30;//0.30;//0.30;//0.61;0.050;// 0.50; //

deltaT          1e-6;//1e-6;//5e-6;//1e-6;//0.000001;

writeControl    adjustableRunTime; // this is to get the exact time written butt too much computational overhead observed
//writeControl    runTime;

writeInterval   0.050;//0.010;//0.020;//0.050;//0.020;//0.025;//0.020;//0.010;//0.050;

purgeWrite      0;

writeFormat     binary;//ascii;//binary;//ascii; 

writePrecision  10;

writeCompression on;//off;

timeFormat      general;

timePrecision   12;//6;

runTimeModifiable true; 




/*
runTimeModifiable no
runTimeModifiable option in controlDict allows the modification of 
problem parameters while the simulations are running. 
But we strongly recommend to set it to no. OpenFOAM simulations tend 
to have a large overhead in the startup phase; the runTimeModifiable 
flag is a major factor in this behavior. 
Turning off this option can greatly reduce this initial overhead and 
result in faster simulations.
source: https://pawsey.atlassian.net/wiki/spaces/US/pages/51925980/OpenFOAM+Best+Practices
*/

adjustTimeStep  yes;//to adjust time step according to maximum Courant number in transient simulation.

maxCo         0.10;//0.20;//0.10;//0.25;//0.20;//0.25;//0.20;//0.30;//0.35;//0.6;//0.9;//1.5;

// OPTION 1: Least restrictive 
// maxDeltaT       0.001;    // 1 millisecond

// OPTION 2: Moderate restriction  (recommended) Δt = 2.5×10⁻⁴ ≈ 0.43 tscale (≈ 43% of tscale) tscale(0.000578s)from ignitionProperties file
maxDeltaT       2.5e-4;   // 1.0e-4;

// OPTION 3: Most restrictive (your current)
// maxDeltaT       1e-5;     // 0.01 millisecond


libs ("libmyCompressibleTurbulenceModels.so");
//libs ("libmyCompressibleTurbulenceModels.so" "libdynamicRefineBalancedFvMesh.so")
//libs ( "libmyCompressibleTurbulenceModels.so" "libdynamicFvMesh.so" "libtopoChangerFvMesh.so" "libdistributed.so" );
