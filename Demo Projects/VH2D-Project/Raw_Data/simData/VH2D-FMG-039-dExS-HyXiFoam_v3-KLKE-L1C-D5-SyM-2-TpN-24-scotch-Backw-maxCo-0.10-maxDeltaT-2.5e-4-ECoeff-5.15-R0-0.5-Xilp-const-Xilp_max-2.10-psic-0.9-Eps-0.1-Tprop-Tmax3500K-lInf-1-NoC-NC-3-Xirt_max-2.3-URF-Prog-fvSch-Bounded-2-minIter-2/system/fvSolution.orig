FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
	 "(p|rho)"
    {
        solver          PCG;
        preconditioner  DIC;
        // tolerance       1e-06;
        // relTol          0.1;
        tolerance       1e-07;//1e-08;
        relTol          0.01;
    }

    "(p|rho)Final"
    {
        $p;
        // tolerance       1e-06;
        tolerance       1e-07;//1e-08;
        relTol          0;
    }
    "pcorr" // added JCAM for AMR
    {
         $p;
         // tolerance       1e-06;
         tolerance       1e-07;//1e-08;
         relTol          0;
    }
    "pcorrFinal" // added JCAM for AMR
    {
         $p;
         // tolerance       1e-06;
         tolerance       1e-07;//1e-08;
         relTol          0;
    }
	 "(U|b|Su|Xi|ha|hau|k|ft|epsilon)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        // tolerance       1e-05;
        // relTol          0.1;
        tolerance       1e-07;//1e-08;
        relTol          0.01;
    };

    "(U|b|Su|Xi|ha|hau|k|ft|epsilon)Final"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        // tolerance       1e-05;
        tolerance       1e-07;//1e-08;
        relTol          0;
	};

}

PIMPLE
{
    momentumPredictor yes;
    /*
    momentumPredictor:
    Set to yes for high Reynolds flows, where convection dominates (default value is yes)
    source: WolfDynamics "supplement_tipsandtricks"
    */
    nOuterCorrectors 100;//3;//2;//1;
    /*
    note: start with nOuterCorrectors 1 then after the ignition cell is fully
    burned ("b" values close to zero) increase the number of 
    nOuterCorrectors 100
    */
    /*
    nOuterCorrectors:
    Recommended value is 1 (equivalent to PISO).
    Increase to improve the stability of second order time discretization 
    schemes (LES simulations). Increase for strongly coupled problems.
    source: WolfDynamics "supplement_tipsandtricks"
    */
    nCorrectors     3;//4;//6;//4;//2; 
    /*nCorrectors: 
    Recommended to use at least 3 correctors.It improves accuracy and stability. 
    Use 4 or more for highly transient flows or strongly coupled problems.
    source: WolfDynamics "supplement_tipsandtricks"
    */
    nNonOrthogonalCorrectors 2;//0;// added by JCAM
    /*
    nNonOrthogonalCorrectors:
    Recommend to use at least 1 corrector.Increase the value for bad quality meshes.
    source: WolfDynamics "supplement_tipsandtricks"
    
    -Check Mesh Results 
    Note: in theory should not be required any nNonOrthogonalCorrectors
    but since the mesh shows an error that I could not figure out how to 
    solve it I added 1 
    Check Mesh------------------------------
    nNonOrthogonalCorrectors
    Mesh non-orthogonality Max: 0 average: 0
    Non-orthogonality check OK.
    ----------------------------------------

    It is recommended to always undertake at least one corrector step. Typical 
    example values for ‘nNonOrthogonalCorrectors’ (depending on the results from
     the checkMesh utility, see Section 4.2) are provided below:
    Non-orthogonality between 70 and 80: ‘nNonOrthogonalCorrectors’ = 3
    Non-orthogonality between 60 and 70: ‘nNonOrthogonalCorrectors’ = 2
    Non-orthogonality between 40 and 60: ‘nNonOrthogonalCorrectors’ = 1
    Non-orthogonality < 40: nNonOrthogonalCorrectors = 0
    source: H2FC Report D10.12 2nd Report on Software Suite

    */
    correctPhi yes; // added JCAM
    /*
    Description
    Flux correction functions to ensure continuity.
    Required during start-up, restart, mesh-motion etc. when non-conservative
    fluxes may adversely affect the prediction-part of the solution algorithm
    (the part before the first pressure solution which would ensure continuity).
    This is particularly important for VoF and other multi-phase solver in
    which non-conservative fluxes cause unboundedness of the phase-fraction.
    source: CorrectPhi.H
    */
    turbOnFinalIterOnly  false ; // added JCAM
    /*
    6 Some hints
    For high turbulent flow fields we should add the 
    keyword turbOnFinalIterOnly = false to calculate the turbulent 
    properties each outer loop too 
    source: https://openfoamwiki.net/index.php/OpenFOAM_guide/The_PIMPLE_algorithm_in_OpenFOAM
    */

    residualControl// added JCAM
    {
        p
        {
                tolerance  1e-5;//1e-1;//1e-8;
                relTol      0;
        }
        U
        {
                tolerance  1e-4;//1e-1;//1e-8;
                relTol      0;
        }
        b
        {
                tolerance  1e-5;//1e-1;//1e-8;
                relTol      0;
        }

     }
}

relaxationFactors// added JCAM
{
    fields
    {
        "U|p|b|ft"      0.4;//0.5;//0.6;//0.7;//0.4;
        "(U|p|b|ft)Final"   1;
    }
    equations
    {
        "(U|p|rho|b|Su|Xi|ha|hau|k|ft|epsilon)"     0.4;//0.5;//0.6;//0.7;//0.4;
        "(U|p|rho|b|Su|Xi|ha|hau|k|ft|epsilon)Final"   1;
    }
} 

// ************************************************************************* //

