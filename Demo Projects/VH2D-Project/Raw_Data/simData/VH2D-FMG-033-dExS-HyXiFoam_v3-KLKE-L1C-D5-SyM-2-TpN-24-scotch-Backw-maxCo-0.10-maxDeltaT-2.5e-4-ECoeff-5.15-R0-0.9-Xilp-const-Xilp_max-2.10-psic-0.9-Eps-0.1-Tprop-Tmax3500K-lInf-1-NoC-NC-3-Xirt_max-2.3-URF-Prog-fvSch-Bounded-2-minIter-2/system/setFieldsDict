FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volScalarFieldValue ft 0
);

regions
(
    boxToCell
    {
        // box(0 - 2.3 0)(4.6 2.3 3);
        // box (0.1 -2.3 0.1) (4.7 2.3 3.1); // added by JCAM
        box (0.1 0.0 0.0) (4.7 2.3 3.0); // correct due symmetry by JCAM
        fieldValues
        (
            volScalarFieldValue ft 0.015
        );
    }
);


