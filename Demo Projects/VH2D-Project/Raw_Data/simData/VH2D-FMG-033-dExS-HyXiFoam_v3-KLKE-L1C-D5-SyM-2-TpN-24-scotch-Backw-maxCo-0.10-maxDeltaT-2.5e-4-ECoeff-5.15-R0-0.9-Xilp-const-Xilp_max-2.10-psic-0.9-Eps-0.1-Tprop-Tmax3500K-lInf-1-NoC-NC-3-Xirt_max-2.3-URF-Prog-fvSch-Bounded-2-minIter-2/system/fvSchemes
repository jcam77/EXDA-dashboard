FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default     backward;
    // If you want extra robustness early on:
    // default  Euler;
    // (then switch later after ignition region is burned)
}

gradSchemes
{
    // Robust default (WD-style): limits gradients without murdering accuracy.
    // 0.5 is a good starting point; 1.0 is often too diffusive for peaks.
    // Key idea: limit gradients enough to stop blow-ups, not enough to kill peaks.
    // Start here and only tweak these two numbers when doing stability work.
        //default       cellMDLimited Gauss linear 0;
        //default         cellMDLimited leastSquares 1.0; //WD-Note: In practice, the leastSquares method is more accurate, however, I have found that it tends to be more oscillatory on tetrahedral meshes.
    
    //default     cellLimited Gauss linear 0;//1.0;//0.5; 
    
    // Make it explicit for the two usual troublemakers:
    // Pressure gradient: be gentle (too aggressive -> peak disappears / shifts)
    //grad(p)     cellLimited Gauss linear 0.333;//0.5;//1.0;//0.5;//0.333;

    // Velocity gradient: moderate limiting helps on vent jets / shear layers
    //grad(U)     cellLimited Gauss linear 0.333;//1.0;//0.5;//0.333;//0.5;//1.0;//0.5;
    
    //grad(U)     faceLimited Gauss linear 0.5;

    //--------------------------------------------------------------------------
    //default     cellMDLimited Gauss linear 0.5;//0.5;
    
    // Make it explicit for the two usual troublemakers:
    // Pressure gradient: be gentle (too aggressive -> peak disappears / shifts)
    //grad(p)     cellMDLimited Gauss linear 0.333;

    // Velocity gradient: moderate limiting helps on vent jets / shear layers
    //grad(U)     cellMDLimited Gauss linear 0.5;//0.333;//0.5;
    
    default         Gauss linear;
}

divSchemes
{
    default                 none;

    // --- Momentum convection -------------------------------------------------
    // Stabilizer test (most diffusive / most robust):
    //div(phi,U)              Gauss upwind;

    // If stable, back off to something less diffusive:
    //div(phi,U)           Gauss linearUpwindV grad(U);
    //div(phi,U)           Gauss linearUpwind grad(U);
    // or your current choice:
    
    div(phi,U)           Gauss limitedLinearV 1.0;
    //div(phi,U)      bounded Gauss limitedLinearV 1.0;
    //div(phi,U)      Gauss vanLeerV;

    // --- Pressure-related convection -----------------------------------------
    div(phid,p)             Gauss limitedLinear 1.0;
    //div(phid,p)      bounded Gauss limitedLinear 1.0;

    // --- K, turbulence, etc. -------------------------------------------------
    div(phi,K)              Gauss limitedLinear 1.0;
    //div(phi,K)      bounded Gauss limitedLinear 1.0;

    div(phi,k)              Gauss limitedLinear 1.0;
    //div(phi,k)      bounded Gauss limitedLinear 1.0;

    div(phi,epsilon)        Gauss limitedLinear 1.0;
    //div(phi,epsilon) bounded Gauss limitedLinear 1.0;

    div(phi,R)              Gauss limitedLinear 1.0;
    div(R)                  Gauss linear;

    // --- Extra Combustion Related --------------------------------------------
    div(phiXi,Xi)           Gauss limitedLinear 1.0;
    //div(phiXi,Xi) bounded Gauss limitedLinear 1.0;

    div(phiXi,Su)           Gauss limitedLinear 1.0;
    //div(phiXi,Su) bounded Gauss limitedLinear 1.0;

    // b must stay strictly bounded [0,1]
    // IMPORTANT: vanLeer01 has no trailing coefficient
    div(phiSt,b)            Gauss vanLeer01;
    
    // Multivariate selection block: keep b strictly bounded
    div(phi,ft_b_ha_hau) Gauss multivariateSelection
    {
        fu      limitedLinear01 1.0;
        ft      limitedLinear01 1.0;

        // Strictly bounded 0..1:
        b       vanLeer01;

        ha      limitedLinear 1.0;//vanLeer;//limitedLinear 1.0;
        hau     limitedLinear 1.0;//vanLeer;//limitedLinear 1.0;
    };

    // These are not the usual culprits, keep as-is
    div(U)                          Gauss linear;
    div((Su*n))                     Gauss linear;
    div((U+((Su*Xi)*n)))            Gauss linear;
    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    // Good “safe” choice on non-orth/skewed meshes:
    default     Gauss linear limited 1.0;

    // If your mesh is genuinely clean and you want accuracy (may destabilize):
    // default  Gauss linear corrected;
}

interpolationSchemes
{
    default     linear;

    // I would NOT start by changing this.
    // If you insist on testing filtered interpolation, do it selectively,
    // not as global default, and only if the scheme exists in your build:
    //
    //interpolate(U) filteredLinear2Linear;
}

snGradSchemes
{
    default     limited 1.0;

    // If mesh is clean and you want accuracy (may destabilize):
    // default corrected;
}

