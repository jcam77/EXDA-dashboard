FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.015;

boundaryField
{
    explosionChamber
    {
        type            kqRWallFunction;
		value           uniform 0.015;
    }
    ground
    {
        type            kqRWallFunction;
		value           uniform 0.015;
    }
    outletFarfield
    {
        type            zeroGradient;
    }
}


