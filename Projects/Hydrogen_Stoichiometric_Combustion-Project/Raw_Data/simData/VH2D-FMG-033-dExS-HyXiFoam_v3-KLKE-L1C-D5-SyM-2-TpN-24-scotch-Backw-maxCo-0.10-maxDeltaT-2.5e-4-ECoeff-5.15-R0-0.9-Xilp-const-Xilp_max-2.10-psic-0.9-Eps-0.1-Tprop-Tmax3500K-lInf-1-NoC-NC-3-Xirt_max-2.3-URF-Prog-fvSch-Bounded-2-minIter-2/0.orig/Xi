FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      Xi;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    explosionChamber
    {
        type            zeroGradient;
    }
    ground
    {
        type            zeroGradient;
    }
    outletFarfield
    {
        type            inletOutlet;
        inletValue      uniform 1;
        value           uniform 1;
    }
}

