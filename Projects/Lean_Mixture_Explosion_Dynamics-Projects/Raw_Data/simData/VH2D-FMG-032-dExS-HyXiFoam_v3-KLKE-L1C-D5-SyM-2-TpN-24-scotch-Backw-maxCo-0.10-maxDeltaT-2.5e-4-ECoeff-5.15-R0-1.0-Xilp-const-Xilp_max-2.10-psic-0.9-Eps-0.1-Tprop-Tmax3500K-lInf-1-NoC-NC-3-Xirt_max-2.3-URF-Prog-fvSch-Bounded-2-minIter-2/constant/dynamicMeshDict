FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dynamicFvMesh      dynamicRefineFvMesh;//3D

//dynamicFvMesh   dynamicRefine2DFvMesh;//2D

//dynamicFvMesh   dynamicRefineBalancedFvMesh; // 3D with Processor Load Balancing

//------------------------------------------------------------------------------
dynamicRefineFvMeshCoeffs
{
    // Extra entries for balancing
    enableBalancing false;//true;

    allowableImbalance 0.15;

    // How often to refine
    refineInterval  5;//1;

    // Field to be refinement on (set it to 'internalRefinementField' to use the
    // refinementControls dictionary entries above)
    field           b;

    // Refine field inbetween lower..upper
    lowerRefineLevel 0.35;//0.25;
    upperRefineLevel 0.65;//0.75; 

    // If value < unrefineLevel unrefine
    unrefineLevel   0.05; 

    // Have slower than 2:1 refinement
    nBufferLayers   1;//4;

    // Refine cells only up to maxRefinement levels
    maxRefinement   1;//3;

    // Stop refinement if maxCells reached
    maxCells        4000000;

    // Flux field and corresponding velocity field. Fluxes on changed
    // faces get recalculated by interpolating the velocity. Use 'none'
    // on surfaceScalarFields that do not need to be reinterpolated.
    correctFluxes
    (
        (phi U)
    );

    // Write the refinement level as a volScalarField
    dumpLevel       true;
}
